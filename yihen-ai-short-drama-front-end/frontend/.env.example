# AI短剧生成系统 - 环境变量配置

# API基础路径
VITE_API_BASE_URL=/api/v1

# 是否启用模拟数据（后端未启动时使用）
VITE_USE_MOCK_DATA=true

# JWT Token存储键名
VITE_AUTH_TOKEN_KEY=auth_token

# 用户信息存储键名
VITE_USER_INFO_KEY=user_info

# 默认每页数量
VITE_DEFAULT_PAGE_SIZE=10

# 最大上传文件大小 (MB)
VITE_MAX_FILE_SIZE=100

# 支持的图片格式
VITE_SUPPORTED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# 支持的视频格式
VITE_SUPPORTED_VIDEO_TYPES=mp4,mov,avi,webm

# 支持的音频格式
VITE_SUPPORTED_AUDIO_TYPES=mp3,wav,ogg,m4a
